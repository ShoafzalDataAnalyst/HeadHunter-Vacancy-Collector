
# ── API ──────────────────────────────────────────────────────
SEARCH_TEXT=data analyst
AREA_ID=97
PER_PAGE=100
TEST_MODE=false
MAX_PAGES_TEST=3
REQUEST_DELAY=0.2
USER_AGENT=hh-uz-collector/2.0 (your@email.com)

# ── SQL Server ───────────────────────────────────────────────
DB_SERVER=your server
DB_NAME=headhunter
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUSTED=yes
DB_CERT=yes

# ── Exit ──────────────────────────────────────────────────
OUTPUT_DIR=output
LOG_LEVEL=INFO
